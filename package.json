{
  "name": "wild-earth",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "elysia": "^1.4.21",
      "@orpc/server": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.5.5",
      "next-themes": "^0.4.6",
      "@orpc/client": "^1.13.14",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @wild-earth/db db:push",
    "db:studio": "turbo -F @wild-earth/db db:studio",
    "db:generate": "turbo -F @wild-earth/db db:generate",
    "db:migrate": "turbo -F @wild-earth/db db:migrate",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@wild-earth/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/bun": "catalog:",
    "@wild-earth/config": "workspace:*",
    "lefthook": "latest",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.6.0"
  },
  "packageManager": "bun@1.3.13"
}
