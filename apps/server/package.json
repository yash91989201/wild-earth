{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@orpc/openapi": "^1.13.14",
    "@orpc/server": "^1.13.14",
    "@orpc/zod": "^1.13.14",
    "@wild-earth/api": "workspace:*",
    "@wild-earth/auth": "workspace:*",
    "@wild-earth/db": "workspace:*",
    "@wild-earth/env": "workspace:*",
    "better-auth": "^1.6.7",
    "dotenv": "^17.4.2",
    "elysia": "^1.4.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@wild-earth/config": "workspace:*",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3"
  }
}
